{
  "manifest_version": 2,
  "name": "QuickSearch – Multi-Engine Launcher",
  "version": "1.0.1",
  "description": "Type your shortcut in the address bar to instantly search any engine or ask any AI model.",
  "author": "QuickSearch Extension",

  "icons": {
    "48":  "icons/icon-48.png",
    "96":  "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "browser_action": {
    "default_icon": {
      "48":  "icons/icon-48.png",
      "96":  "icons/icon-96.png"
    },
    "default_title": "QuickSearch Settings",
    "default_popup": "popup/popup.html"
  },

  "omnibox": {
    "keyword": "@s"
  },

  "background": {
    "scripts": ["engines.js", "background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["content/perplexity.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "quicksearch@extension",
      "strict_min_version": "91.0",
      "data_collection_permissions": {
        "required": []
      }
    }
  }
}
